generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         String   @default("USER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sportInterests  UserSport[]
  gameRosters     GameRoster[]
  sentInvites     Invite[]      @relation("InviteSender")
  receivedInvites Invite[]      @relation("InviteRecipient")
  chatMessages    ChatMessage[]
  sessions        Session[]
  feedFollows     FeedFollow[]
  createdSlots    GameSlot[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Sport {
  id   String @id @default(cuid())
  slug String @unique
  name String
  icon String @default("🏃")

  userInterests UserSport[]
  gameSlots     GameSlot[]
}

model UserSport {
  userId  String
  sportId String
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport   Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@id([userId, sportId])
}

model GameSlot {
  id          String   @id @default(cuid())
  sportId     String
  creatorId   String
  title       String
  description String?
  location    String
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int      @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sport    Sport        @relation(fields: [sportId], references: [id])
  creator  User         @relation(fields: [creatorId], references: [id])
  rosters  GameRoster[]
  invites  Invite[]
  messages ChatMessage[]
}

model GameRoster {
  id         String   @id @default(cuid())
  gameSlotId String
  userId     String
  joinedAt   DateTime @default(now())

  gameSlot GameSlot @relation(fields: [gameSlotId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameSlotId, userId])
}

model Invite {
  id          String    @id @default(cuid())
  gameSlotId  String
  senderId    String
  recipientId String?
  phone       String?
  status      String    @default("PENDING")
  token       String    @unique @default(cuid())
  sentAt      DateTime  @default(now())
  respondedAt DateTime?

  gameSlot  GameSlot @relation(fields: [gameSlotId], references: [id], onDelete: Cascade)
  sender    User     @relation("InviteSender", fields: [senderId], references: [id])
  recipient User?    @relation("InviteRecipient", fields: [recipientId], references: [id])
}

model ChatMessage {
  id         String   @id @default(cuid())
  gameSlotId String
  userId     String
  body       String
  createdAt  DateTime @default(now())

  gameSlot GameSlot @relation(fields: [gameSlotId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
}

model FeedFollow {
  id     String @id @default(cuid())
  userId String
  league String
  sport  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, league])
}
